# Supabase - Armazenamento em nuvem e autenticação
# Crie um projeto em https://supabase.com e copie as credenciais
# Execute supabase/migrations/001_create_user_data.sql no SQL Editor do Supabase
# Em Auth → URL Configuration, adicione às Redirect URLs:
#   http://localhost:3000/auth/callback (dev)
#   https://seu-dominio.com/auth/callback (produção)

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica
